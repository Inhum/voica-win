<Window x:Class="Voica.UI.DeleteDataDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:Voica"
        Title="{x:Static l:S.DeleteDataTitle}" Width="420" SizeToContent="Height"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock TextWrapping="Wrap" Text="{x:Static l:S.DeleteDataWarning}" />
        <TextBlock x:Name="InstructionText" Margin="0,12,0,4" TextWrapping="Wrap" />
        <TextBox x:Name="ConfirmBox" TextChanged="OnTextChanged" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="DeleteButton" Content="{x:Static l:S.BtnDeleteEverything}" Width="150" Height="28"
                    Margin="0,0,8,0" IsEnabled="False" Foreground="#C0392B" Click="OnConfirm" />
            <Button Content="{x:Static l:S.BtnCancel}" Width="90" Height="28" IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>
