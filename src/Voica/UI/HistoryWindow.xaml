<Window x:Class="Voica.UI.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:Voica"
        Title="{x:Static l:S.HistoryTitle}" Width="720" Height="480"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid x:Name="Grid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  CanUserResizeRows="False"
                  RowHeight="26"
                  MouseDoubleClick="OnCopy">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static l:S.ColWhen}" Binding="{Binding When}" Width="150" />
                <DataGridTextColumn Header="{x:Static l:S.ColText}" Binding="{Binding Preview}" Width="*" />
                <DataGridTextColumn Header="{x:Static l:S.ColLang}" Binding="{Binding Lang}" Width="70" />
                <DataGridTextColumn Header="{x:Static l:S.ColDur}" Binding="{Binding Duration}" Width="60" />
                <DataGridTextColumn Header="{x:Static l:S.ColModel}" Binding="{Binding ModelName}" Width="150" />
                <DataGridTextColumn Header="{x:Static l:S.ColAudio}" Binding="{Binding AudioMark}" Width="55" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
            <Button x:Name="CopyButton" Content="{x:Static l:S.BtnCopy}" Width="90" Height="28" Margin="0,0,8,0" Click="OnCopy" />
            <Button x:Name="PlayButton" Content="{x:Static l:S.BtnPlay}" Width="90" Height="28" Margin="0,0,8,0" Click="OnPlay" />
            <Button x:Name="DeleteButton" Content="{x:Static l:S.BtnDelete}" Width="90" Height="28" Margin="0,0,8,0" Click="OnDelete" />
            <Button Content="{x:Static l:S.BtnRefresh}" Width="90" Height="28" Margin="0,0,8,0" Click="OnRefresh" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="8,0,0,0" Opacity="0.7" />
        </StackPanel>
    </Grid>
</Window>
